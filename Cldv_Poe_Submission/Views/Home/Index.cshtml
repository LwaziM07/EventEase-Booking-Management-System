@model IEnumerable<SummaryModel>

@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    
    <h1 class ="text-center"> EventEase Dashboard</h1>
    <div class="row g-4 justify-content-center">

        <div class="col-lg-4 col-md-6">
            <div class="card p-3">
                <img src="https://plus.unsplash.com/premium_photo-1664530452329-42682d3a73a7?q=80&w=872&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top venue-image" alt="Venues">
                <div class="card-body">
                    <h3 class="card-title">
                        Venues
                    </h3>
                    <p>
                        View, add and manage venues for events. Each venue has a location, capacity and an image to view as you please.
                    </p>
                    <a asp-controller="Venues" asp-action="Index" class="btn btn-primary">Manage Venues</a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="card p-3">
                <img src="https://images.unsplash.com/photo-1527529482837-4698179dc6ce?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top venue-image" alt="Events">                <div class="card-body">
                    <h3 class="card-title">
                        Events
                    </h3>
                    <p>
                        View, add and manage all upcoming events. With assigned dates, venues and specialists for fluid coordination.
                    </p>
                    <a asp-controller="Events" asp-action="Index" class="btn btn-primary">Manage Events</a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="card p-3">
                <img src="https://images.unsplash.com/photo-1567748534085-467f8a8a475d?w=400&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8N3x8dGlja2V0fGVufDB8fDB8fHww" class="card-img-top venue-image" alt="Bookings">
                <div class="card-body">
                    <h3 class="card-title">
                        Bookings
                    </h3>
                    <p>
                        Keep track of all bookings made, including venues, events and specialists assigned to each booking.
                    </p>
                    <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary">Manage Bookings</a>
                </div>
            </div>
        </div>

    </div>
        <h2 class="text-center mb-3"> Booking Summary </h2>
    <div class="card p-3">
        

        <table class="table">
            <thead>
                <tr>
                    
                    <th>
                        @Html.DisplayNameFor(model => model.BookingDate)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.SpecialistName)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.VenueName)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.EventName)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.BookingDate)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.SpecialistName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.VenueName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.EventName)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>