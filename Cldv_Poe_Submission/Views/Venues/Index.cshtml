@model IEnumerable<Cldv_Poe_Submission.Models.Venue>

@{
    ViewData["Title"] = "Index";
}

<h1>Manage Venues</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<div class="card p-3">
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.VenueName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.VenueLocation)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Capacity)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.ImageUrl)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.VenueName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.VenueLocation)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Capacity)
                    </td>
                    <td>
                        <img src=@Html.DisplayFor(modelItem => item.ImageUrl) width="150" height="50" />
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

